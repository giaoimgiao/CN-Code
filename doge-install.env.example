# Copy to doge-install.env (gitignored). Fixes IDE-injected bogus HTTP_PROXY + DNS pollution.
#
# Without this file, install:env clears inherited HTTP(S)_PROXY then probes ports 7890, 7897, 10809.
# To keep parent env proxy instead: TRUST_SYSTEM_PROXY=1 in the shell before bun run install:env

# Clash Verge: 混合端口常是 7898；若只开 HTTP(S) 端口则用 7899（以你软件里实际开启的为准）
HTTP_PROXY=http://127.0.0.1:7898
HTTPS_PROXY=http://127.0.0.1:7898
NO_PROXY=127.0.0.1,localhost

# PROXY_AUTODETECT=0
# ALL_PROXY=socks5://127.0.0.1:10808
# BUN_INSTALL_PROBE_DNS=1
